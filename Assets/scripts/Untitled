// UIZoneTrigger.cs
using UnityEngine;
using UnityEngine.EventSystems;

// 🔹 Вешается на прозрачный Image в Canvas
public class UIZoneTrigger : MonoBehaviour, IPointerClickHandler
{
    [Tooltip("Ссылка на ItemTriggerZone (логическую зону)")]
    public ItemTriggerZone targetZone;

    public void OnPointerClick(PointerEventData eventData)
    {
        targetZone?.ShowDetail();
    }
}
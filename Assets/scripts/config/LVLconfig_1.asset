  IntroDialog: "\u0422\u043E\u043B\u044C\u043A\u043E \u043F\u0435\u0440\u0435\u0432\u0435\u043B\u0441\u044F,
    \u0430 \u0443\u0436\u0435 \u0434\u0430\u043B\u0438 <b><color=#FFD800>\u043D\u043E\u0432\u043E\u0435
    \u0434\u0435\u043B\u043E</color></b>. \u041D\u0430\u0434\u043E \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u044C\u0441\u044F
    \u0441 \u043D\u0438\u043C\u2026 \u041A\u0430\u043A\u0430\u044F \u043F\u043E\u0433\u043E\u0434\u0430
    <b><color=#FFD800>\u0437\u0430 \u043E\u043A\u043D\u043E\u043C</color></b>? \u0425\u043C,
    \u043F\u0430\u0441\u043C\u0443\u0440\u043D\u043E. \u041D\u0435 \u043B\u0443\u0447\u0448\u0435\u0435
    \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u043F\u043E\u0438\u0441\u043A\u043E\u0432.
    \u041E, \u0434\u0430\u0436\u0435 <b><color=#FFD800>\u043A\u0430\u0440\u0442\u0430
    \u0433\u043E\u0440\u043E\u0434\u0430</color></b> \u0435\u0441\u0442\u044C \u0432
    \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435! \u0418\u0437\u0443\u0447\u0443
    \u0435\u0451 \u043F\u043E\u0437\u0436\u0435 \u2014 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0434\u0435\u043B\u043E."
  OutroDialog: "\u042D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0441
    \u043F\u0440\u043E\u043F\u0430\u0436\u0435\u0439 \u0434\u0435\u0442\u0435\u0439\u2026
